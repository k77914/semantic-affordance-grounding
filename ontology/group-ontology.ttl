@prefix cap:     <https://hcis.io/ontology/aicapstone/2026/> .
@prefix g13:     <https://hcis.io/ontology/aicapstone/2026/group13/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann:    <http://purl.org/vocab/vann/> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .

<https://hcis.io/ontology/aicapstone/2026/group13/>
    a owl:Ontology ;
    rdfs:label "Group 13 Semantic Affordance Grounding Ontology"@en ;
    rdfs:comment
        "A group-authored ontology for grounding course task objects, task roles, manipulation affordances, and inferred graspability."@en ;
    dcterms:title "Group 13 Semantic Affordance Grounding Ontology"@en ;
    dcterms:description
        "This ontology defines group-specific object instances for the AI Capstone semantic grounding homework and uses OWL reasoning to infer graspable objects."@en ;
    dcterms:creator g13:group13 ;
    dcterms:created "2026-06-01"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:imports <imports/course-affordance.ttl>,
                <imports/course-alignment.ttl> ;
    vann:preferredNamespacePrefix "g13" ;
    vann:preferredNamespaceUri "https://hcis.io/ontology/aicapstone/2026/group13/" .

#################################################################
# Group and member metadata
#################################################################

g13:group13
     a foaf:Group ;
     rdfs:label "Group 13"@en ;
     rdfs:comment
         "The student group that authored this ontology for AI Capstone Homework 5."@en ;
     foaf:name "Group 13"@en ;
     foaf:member g13:member01,
                 g13:member02,
                 g13:member03,
                 g13:member04,
                 g13:member05,
                 g13:member06 .

